# FastAPI base (no trailing slash)
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Canonical URL for Open Graph / metadata (your deploy URL or http://localhost:3010)
# NEXT_PUBLIC_SITE_URL=http://localhost:3010

# When backend AUTH_MODE=api_key, set the same key as API_KEYS (comma-separated on server uses first key here).
# NEXT_PUBLIC_API_KEY=

# Optional explicit WebSocket URL (defaults from API base + /api/v1/ws/alerts + ?api_key=)
# NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1/ws/alerts
