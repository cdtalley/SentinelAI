DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentinelai
MODEL_DIR=./app/models/ml
MODEL_VERSION=v1.0
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3
OLLAMA_ENABLED=true
FRAUD_THRESHOLD_BLOCK=0.75
FRAUD_THRESHOLD_REVIEW=0.35
DRIFT_CHECK_WINDOW=1000
DRIFT_PSI_THRESHOLD=0.2
WEBSOCKET_HEARTBEAT_SECONDS=25

# production posture
APP_ENV=development
EXPOSE_ERROR_DETAILS=false
CORS_ORIGINS=*
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
